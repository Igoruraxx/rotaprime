# ═══════════════════════════════════════════════════════════════
# Rota Prime — Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════════
# Crie um arquivo .env.local na raiz do projeto com seus valores
# As variáveis NEXT_PUBLIC_* são seguras e vão para o client-side
# ═══════════════════════════════════════════════════════════════

# ─── Supabase ─────────────────────────────────────────────────
# Crie um projeto grátis em: https://supabase.com/dashboard
# Vá em Settings → API e copie os valores abaixo:

NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.sua-chave-anon-publica-aqui

# ─── Supabase Service Role (SECRETO — NUNCA compartilhar) ────
# Settings → API → service_role key (NUNCA expor no client-side)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.sua-chave-service-role-aqui

# ─── Opcionais ────────────────────────────────────────────────
# JWT_SECRET: usado para CSRF tokens. Gere um com: openssl rand -hex 32
JWT_SECRET=seu-jwt-secret-aqui-pelo-menos-32-caracteres
